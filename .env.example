# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Firebase
REACT_APP_FB_KEY=your-firebase-api-key
REACT_APP_FB_PROJECT=your-firebase-project-id
REACT_APP_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id

# Gemini AI
REACT_APP_GEMINI_KEY=your-gemini-api-key

# Admin panel (optional - leave empty to disable admin)
REACT_APP_ADMIN_PASS=your-admin-password
